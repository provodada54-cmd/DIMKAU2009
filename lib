            Button.Label.Visible = not IsCompact
            Button.Padding.PaddingBottom = UDim.new(0, IsCompact and 4 or 8)
            Button.Padding.PaddingLeft = UDim.new(0, IsCompact and 4 or 8)
            Button.Padding.PaddingRight = UDim.new(0, IsCompact and 4 or 8)
